{
  "name": "watchmate-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cli": "node src/runtime/cli.js",
    "watchmate:cli": "./watchMate-cli/watchMate-cli",
    "watchmate:mcp:stdio": "node watchMate-cli/mcp/server.mjs --transport stdio",
