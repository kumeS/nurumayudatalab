{
  "manifest_version": 3,
  "name": "EC AI Assistant",
  "version": "0.2.0",
  "description": "1688商品ページの解析機能を強化（window.context優先抽出、価格クリーニング）。日本語要約・キーワード生成ジョブを管理します。",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://*.1688.com/*",
    "https://*.workers.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ジョブ管理を開く"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.1688.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/manager.html",
    "open_in_tab": true
  }
}
